# Steadfirm Infrastructure Environment Variables

# Database
DB_USER=steadfirm
DB_PASSWORD=changeme
DATABASE_URL=postgresql://steadfirm:changeme@localhost:5432/steadfirm

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Domain (used by Caddyfile)
DOMAIN=localhost

# File storage for unclassified uploads
FILES_STORAGE_PATH=/data/steadfirm/files

# Service URLs (auto-configured when using Docker Compose)
# IMMICH_URL=http://immich-server:2283
# IMMICH_API_KEY=
# JELLYFIN_URL=http://jellyfin:8096
# JELLYFIN_API_KEY=
# PAPERLESS_URL=http://paperless:8000
# PAPERLESS_TOKEN=
# AUDIOBOOKSHELF_URL=http://audiobookshelf:80
# AUDIOBOOKSHELF_TOKEN=
