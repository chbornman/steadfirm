# Steadfirm Infrastructure Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# Database
DB_USER=steadfirm
DB_PASSWORD=changeme

# BetterAuth (Bun sidecar)
# Generate with: openssl rand -hex 32
BETTERAUTH_SECRET=generate-a-random-secret-here
BETTERAUTH_URL=http://localhost:18080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain (used by Caddyfile — set to your domain in production)
DOMAIN=localhost

# ──────────────────────────────────────────────
# Host-exposed ports (all 18000+)
# ──────────────────────────────────────────────
# Only Caddy is exposed to the network.
# Postgres and Valkey are on 127.0.0.1 for host-side admin only.
# All other services have NO host ports — internal network only.
#
# Caddy HTTP:     18080  (public — the only entry point)
# Caddy HTTPS:    18443  (public — the only entry point)
# Postgres:       127.0.0.1:18432  (host admin only)
# Valkey:         127.0.0.1:18379  (host admin only)
