# Steadfirm Caddyfile
# Replace {$DOMAIN} with your domain or use localhost for development.
#
# In production, pair with Cloudflare Tunnel:
#   cloudflared tunnel --url http://localhost:80
#
# v1: All traffic goes through the Steadfirm backend API.
# Direct service access (power user mode) is a future roadmap item.

{$DOMAIN:localhost} {
    # Steadfirm backend API
    handle /api/* {
        reverse_proxy steadfirm-backend:3001
    }

    # Default: serve the web frontend
    handle {
        # reverse_proxy steadfirm-web:3000
        respond "Steadfirm web frontend — pending" 200
    }
}
